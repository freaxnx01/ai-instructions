# Reference justfile for .NET projects using the dotnet stack overlay.
# See ../../references/dotnet/justfile-recipes.md for the canonical recipe
# names and rationale. Copy this file to your repo root and customize the
# variables below.
#
# Requires just >= 1.20 (for [group(...)] attributes).
# Install:
#   Linux:   sudo apt install just  (or: cargo install just)
#   macOS:   brew install just
#   Windows: winget install Casey.Just  (or: scoop install just)

set windows-shell := ["pwsh", "-NoLogo", "-NonInteractive", "-Command"]
set dotenv-load
set positional-arguments

# ── Project Configuration ────────────────────────────────────────────────────

# TODO: set to your solution file
sln                := "source/YourProject.sln"

# TODO: set to your main API / host project directory
api_dir            := "source/YourProject.Api"

# TODO: set to your frontend project directory (delete if no separate frontend)
client_dir         := "source/YourProject.Client"

# Path to the file that holds the single <Version>X.Y.Z</Version> element.
# Convention: Directory.Build.props at the solution root.
props_file         := "source/Directory.Build.props"

# Compose files
compose            := "docker compose -f docker-compose.yml -f docker-compose.override.yml"

# Test projects — space-separated; add/remove as needed
test_unit_projects := "source/YourProject.UnitTests"

# ── Default ──────────────────────────────────────────────────────────────────

# Show this help (`just` with no args)
default:
    @just --list --unsorted

# ── Build & run ──────────────────────────────────────────────────────────────

# Build solution in Release mode
[group('build')]
build:
    dotnet build {{sln}} -c Release

# Run API with hot reload
[group('build')]
watch:
    cd {{api_dir}} && dotnet watch

