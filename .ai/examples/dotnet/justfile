# ── Cleanup ──────────────────────────────────────────────────────────────────

# Remove build artifacts
[group('cleanup')]
[unix]
clean:
    find . -type d \( -name bin -o -name obj -o -name publish \) -exec rm -rf {} + 2>/dev/null || true
    rm -rf coverage/

[group('cleanup')]
[windows]
clean:
    #!/usr/bin/env pwsh
    Get-ChildItem -Path . -Include bin,obj,publish -Recurse -Directory -ErrorAction SilentlyContinue | Remove-Item -Recurse -Force
    if (Test-Path coverage) { Remove-Item -Recurse -Force coverage }
